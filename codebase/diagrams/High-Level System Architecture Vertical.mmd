%%{init: {"flowchart": {"defaultRenderer": "elk", "htmlLabels": true}} }%%
graph TD
    classDef hardware fill:#f9f9f9,stroke:#333,stroke-width:2px;
    classDef script fill:#e1f5fe,stroke:#0277bd,stroke-width:2px,stroke-dasharray: 5 5;
    classDef data fill:#fff3e0,stroke:#ef6c00,stroke-width:2px;
    classDef model fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px;
    
    subgraph SG_Ingestion ["<b style='font-size:18px'>1. Data Acquisition & Ingestion</b>"]
        direction LR
        NASAPDS[(NASA PDS <br/> Node)]:::hardware -.-> LinkList(url_list.txt):::data
        LinkList --> WgetScript[[auto_wget.sh <br/> Bash Script]]:::script
        WgetScript --> RawStore[(Raw Data <br/> TIFF/IMG)]:::data
    end
    
    subgraph SG_Preproc ["<b style='font-size:18px'>2. Pre-processing & Caching</b>"]
        direction LR
        PyPreproc[[process.py <br/> MapDataset Module]]:::script --> Step1[Surface Alignment <br/> & Horizon Tracking]
        Step1 --> Step2[Tiling / Patching <br/> 256x256 px]
        Step2 --> Step3[Normalization <br/> MinMax / Log]
        Step3 --> CacheStore[(Processed Cache <br/> Binary Chunks)]:::data
    end
    
    subgraph SG_Train ["<b style='font-size:18px'>3. CycleGAN Training Loop</b>"]
        direction LR
        DataLoader(PyTorch DataLoader):::script --> GPU_Env
        
        subgraph GPU_Env [GPU Environment - Docker]
            direction TB
            GenG(Generator G <br/> Sim->Real):::model
            GenF(Generator F <br/> Real->Sim):::model
            Disc(Discriminators):::model
            Loss[Cycle Consistency <br/> + GAN Loss]
            
            GenG <--> Loss
            GenF <--> Loss
            Disc -.- Loss
        end
    end
    
    subgraph SG_Infer ["<b style='font-size:18px'>4. Anomaly Detection Application</b>"]
        direction LR
        SimInput(Simulated Input):::data --> TrainedGen(Trained Gen G):::model
        RealRef(Real Reference):::data --> DiffMap(Difference Map):::data
        TrainedGen --> DiffMap
        DiffMap --> Threshold{Thresholding <br/> Z-Score}
        Threshold --> Result(Anomaly Mask):::data
    end
    
    %% Connessioni SOLO tra i blocchi esterni (nessuna freccia attraversa i confini)
    SG_Ingestion --> SG_Preproc
    SG_Preproc --> SG_Train
    SG_Train --> SG_Infer